#!/usr/bin/env python3

with open('example') as f:
    distances, tiles = [], [tuple(map(int, l.split(','))) for l in f.read().splitlines()]

for i, t1 in enumerate(tiles):
    for t2 in tiles[i + 1:]:
        d = (t1[0] - t2[0]) ** 2 + (t1[1] - t2[1]) ** 2
        distances.append([d, t1, t2])

distances.sort(key=lambda t: t[0])

for d in distances:
    print(d)

d_max = distances[-1]
print(d_max)

d1_x = d_max[1][0]
d2_x = d_max[2][0]
print(d1_x, d2_x)

d1_y = d_max[1][1]
d2_y = d_max[2][1]
print(d1_y, d2_y)

d1_diff = d1_x - d2_x
d2_diff = d1_y - d2_y
print(d1_diff, d2_diff)

if d1_diff < 0:
    d1_diff -= 1
else:
    d1_diff += 1

if d2_diff < 0:
    d2_diff -= 1
else:
    d2_diff += 1

area = abs(d1_diff * d2_diff)
print(area)

